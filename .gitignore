# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# worktrees
.worktrees/

# QA pipeline working artifacts
.qa/

# Pipeline — ignore operational/temporary data, commit instrument state
# Committed: state.json, manifest.json, manifest-editor.json, templates.json, inferred-layout.json
# Ignored: logs, costs, agent checkpoints, manuals, photos, backups
.pipeline/*/runner.log
.pipeline/*/cost.json
.pipeline/*/backups/
.pipeline/*/"backups 2"/
.pipeline/*/agents/
.pipeline/*/input/
.pipeline/*/*.stale
.pipeline/saved/

# Playwright MCP auto-captures
.playwright-mcp/

# QA/audit screenshots
docs/**/screenshots/

# Instrument manuals and large binaries (kept locally/iCloud, not in repo)
docs/**/*.pdf

# QA screenshots (generated, not reference)
docs/**/screenshots/*.png
docs/**/screenshots/*.jpg

# Hardware reference photos ARE committed (needed by QA agents)
# docs/**/photos/ is NOT ignored

# Prevent stray screenshots in project root
/*.png
.pipeline/*/state-backup-*.json
.pipeline/*/state.json

# ─── iCloud duplicate files ─────────────────────────────────────────────
# macOS/iCloud Drive renames sync-conflicted files by appending " 2" before
# the extension (e.g., "foo.ts" → "foo 2.ts"). These pollute the working
# tree and `git status`. Pattern is tuned for that exact convention; if you
# legitimately need a file like "Phase 2.md", use `git add -f` to override.
* 2.ts
* 2.tsx
* 2.js
* 2.jsx
* 2.mjs
* 2.cjs
* 2.json
* 2.md
* 2.mdx
* 2.png
* 2.jpg
* 2.jpeg
* 2.gif
* 2.svg
* 2.log
* 2.yml
* 2.yaml
* 2.txt
* 2.sh
* 2.css
# Extensionless dupes too (e.g., ".githooks/pre-push 2", build artifacts).
* 2

# ─── Manifest editor backups (per-device runtime artifacts) ─────────────
# Created by the editor's auto-save throttle. Rotated on disk; not source.
.pipeline/*/manifest-editor-backup-*.json
.pipeline/*/manifest-editor-backup-pre-*.json
.env*.local
