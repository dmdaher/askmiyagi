# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# worktrees
.worktrees/

# QA pipeline working artifacts
.qa/

# Pipeline runner working directory
.pipeline/

# Playwright MCP auto-captures
.playwright-mcp/

# QA/audit screenshots
docs/**/screenshots/

# Instrument manuals and large binaries (kept locally/iCloud, not in repo)
docs/**/*.pdf

# QA screenshots (generated, not reference)
docs/**/screenshots/*.png
docs/**/screenshots/*.jpg

# Hardware reference photos ARE committed (needed by QA agents)
# docs/**/photos/ is NOT ignored

# Prevent stray screenshots in project root
/*.png
